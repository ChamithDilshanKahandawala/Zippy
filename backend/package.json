{
  "name": "zippy-backend",
  "version": "1.0.0",
  "description": "Zippy Uber Clone - Express + Firebase Admin backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "lsof -ti :${PORT:-3000} | xargs kill -9 2>/dev/null; ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.19.2",
    "firebase": "^12.9.0",
    "firebase-admin": "^12.7.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@types/socket.io": "^3.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
